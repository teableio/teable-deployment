# ============================================================================
# Teable cloud deployment config -- the only file you need to edit.
#   cp .env.cloud.example .env
#   Edit the "required" entries below; apply.sh auto-fills/derives blank secrets and addresses
#   ./apply.sh cloud && docker compose up -d      (add --with-app for all-in-one)
# There is a single domain concept: BASE_DOMAIN. All services split off this one root domain --
#   main site = root domain; console = infra.<root>; object storage = s3.<root>; git = git.<root>;
#   app previews = *.app.<root>; sandbox previews = *.sandbox.<root>.
# Only the console/site hosts can be moved to different domains (see the "Advanced" section at the end of this file);
# the s3. / git. / *.app. / *.sandbox. subdomains are derived from BASE_DOMAIN and not separately configurable in this version.
# ============================================================================

# === Compose ===
# apply.sh fixes this line and adds docker-compose.override.yml (git keys); afterwards plain docker compose up -d works.
COMPOSE_FILE=compose.yaml:compose.cloud.yaml

# === Domain and TLS (required; the only three lines that need thought) ===
# DNS setup (required, done by you): create DNS A/AAAA records pointing at this machine for
#   <BASE_DOMAIN>, infra.<BASE_DOMAIN>, s3.<BASE_DOMAIN>, git.<BASE_DOMAIN>, *.app.<BASE_DOMAIN>, *.sandbox.<BASE_DOMAIN>
#   (DNS-only / no proxy). The Cloudflare token below only answers DNS-01 challenges; it does not create these records.
# Deployment root domain: all services split off it (see file header).
BASE_DOMAIN=teable.example.com
# Let's Encrypt account email.
ACME_EMAIL=you@example.com
# Cloudflare API token; needs Zone:Read + DNS:Edit (used for DNS-01 wildcard certificate issuance).
CLOUDFLARE_API_TOKEN=

# === Secrets (leave blank; apply.sh generates random values) ===
# One key shared by the whole stack (engine / Infra API / console login / git internal).
OPENSANDBOX_API_KEY=
# Console session signing secret.
SESSION_SECRET=
# MinIO root user / password (= artifact-store S3 access / secret keys).
S3_ACCESS_KEY=
S3_SECRET_KEY=

# === Images ===
# First-party images: this file is the single source of tags. All default images are publicly pullable; docker login ghcr.io only if you substitute private ones.
# Infra Service / Git Registry image (one image serves both).
INFRA_SERVICE_IMAGE=ghcr.io/teableio/teable-infra-service:latest
# Sandbox engine (OpenSandbox server).
OPENSANDBOX_SERVER_IMAGE=ghcr.io/teableio/opensandbox-server:v0.2.0-fix4
# Sandbox agent image PREFIX -- no tag. Teable launches AI sessions with
# <prefix>:<its own release tag>, so the agent always matches the app version,
# and it preheats that image through the Infra API on startup.
# China deployments: use the Aliyun mirror prefix instead:
#   registry.cn-shenzhen.aliyuncs.com/teable/teable-sandbox-agent
SANDBOX_OPENSANDBOX_IMAGE=ghcr.io/teableio/teable-sandbox-agent
# App runtime base image (must match the allowlist below; if blank, apps cannot deploy).
APP_RUNTIME_DEFAULT_IMAGE=ghcr.io/teableio/teable-app-runtime:latest
# Allowed app image prefixes (comma-separated; must include the default image's prefix above).
APP_RUNTIME_ALLOWED_IMAGE_PREFIXES=ghcr.io/teableio/
# Registry prefix for the sandbox execution-plane images (execd/egress). Default is the public distribution registry (Aliyun-hosted, anonymously pullable worldwide).
OPENSANDBOX_REGISTRY=sandbox-registry.cn-zhangjiakou.cr.aliyuncs.com/opensandbox
# Third-party images default to :latest; pin digests here for production (get the sha256 via `docker compose images minio`):
# MINIO_IMAGE=minio/minio@sha256:...
# MINIO_MC_IMAGE=minio/mc@sha256:...

# === Artifact store S3 / MinIO ===
S3_BUCKET=teable-app-artifacts
S3_REGION=us-east-1

# === Networks (rarely changed; read by both compose and opensandbox.toml; rename only here) ===
APP_RUNTIME_DOCKER_NETWORK=teable-appnet
SANDBOX_DOCKER_NETWORK=teable-sandbox-net

# ============================================================================
# === Teable app (all-in-one) -- enabled only with ./apply.sh cloud --with-app ===
# Without --with-app this whole section can be ignored. The main site takes the root domain; the console automatically yields to infra.<BASE_DOMAIN>.
# ============================================================================

# Teable app image. Docker deployments work out of the box with latest;
# to pin a version (recommended for production) run ./pin-image.sh, which resolves and writes it back here;
# for Kubernetes, paste the resolved reference into the image fields of your values.
TEABLE_IMAGE=ghcr.io/teableio/teable:latest
# Container timezone.
TIMEZONE=UTC

# --- Database / cache (leave passwords blank to auto-generate; PG publishes no host port) ---
TEABLE_DB_IMAGE=postgres:15.4
TEABLE_DB_NAME=teable
TEABLE_DB_USER=teable
TEABLE_DB_PASSWORD=
TEABLE_REDIS_IMAGE=redis:7.2.4
TEABLE_REDIS_PASSWORD=

# --- Attachment storage buckets ---
TEABLE_PUBLIC_BUCKET=teable-public
TEABLE_PRIVATE_BUCKET=teable-private

# --- Secrets (leave blank to auto-generate; the source-code defaults are public hardcoded values, so public deployments must generate per host) ---
BACKEND_STORAGE_ENCRYPTION_KEY=
BACKEND_STORAGE_ENCRYPTION_IV=
SANDBOX_JWT_SECRET=

# ============================================================================
# === Advanced (optional) -- relocate the console/site hosts. Usually untouched: leave blank to derive everything from BASE_DOMAIN ===
# Only the console/site hosts are relocatable (INFRA_HOST / TEABLE_HOST / PUBLIC_ORIGIN / the attachment endpoint below);
# the s3. / git. / *.app. / *.sandbox. subdomains are derived from BASE_DOMAIN and not separately configurable in this version.
# Your values win, apply.sh does not overwrite them.
# ============================================================================

# Infra console entry (default: infra.<BASE_DOMAIN> with --with-app, <BASE_DOMAIN> for infra-only).
INFRA_HOST=
# Teable main site host (default = BASE_DOMAIN root; takes effect with --with-app).
TEABLE_HOST=
# Public origin (default https://<TEABLE_HOST>).
PUBLIC_ORIGIN=
# Attachment public endpoint (defaults s3.<BASE_DOMAIN> / 443 / true; shares the s3. entry with artifacts, different buckets).
TEABLE_MINIO_ENDPOINT_HOST=
TEABLE_MINIO_ENDPOINT_PORT=
TEABLE_MINIO_USE_SSL=
