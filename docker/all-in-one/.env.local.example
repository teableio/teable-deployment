# ============================================================================
# Teable local deployment config.
#   cp .env.local.example .env
#   ./apply.sh local   # auto-fills secrets / probes the LAN IP to derive addresses / renders the toml / fixes COMPOSE_FILE
#   docker compose up -d        # first run pulls images automatically
# Local mode has no domain concept: everything is *.localhost + the machine's LAN IP, fully auto-derived, zero manual input.
# apply.sh auto-fills blank entries.
# ============================================================================

# === Compose ===
# apply.sh fixes this line and adds docker-compose.override.yml (git keys); afterwards plain docker compose up -d works.
COMPOSE_FILE=compose.yaml:compose.local.yaml

# === Secrets (leave blank; apply.sh generates random values) ===
# One key shared by the whole stack (engine / Infra API / console login / git internal).
OPENSANDBOX_API_KEY=
# Console session signing secret.
SESSION_SECRET=
# MinIO root user / password (= artifact-store S3 access / secret keys).
S3_ACCESS_KEY=
S3_SECRET_KEY=

# === Images ===
# Infra Service / Git Registry image (one image serves both).
INFRA_SERVICE_IMAGE=ghcr.io/teableio/teable-infra-service:latest
# Sandbox engine (OpenSandbox server).
OPENSANDBOX_SERVER_IMAGE=ghcr.io/teableio/opensandbox-server:v0.2.0-fix5
# Sandbox agent image PREFIX -- no tag. Teable launches AI sessions with
# <prefix>:<its own release tag>, so the agent always matches the app version,
# and it preheats that image through the Infra API on startup.
# China deployments: use the Aliyun mirror prefix instead:
#   registry.cn-shenzhen.aliyuncs.com/teable/teable-sandbox-agent
SANDBOX_OPENSANDBOX_IMAGE=ghcr.io/teableio/teable-sandbox-agent
# App runtime base image (must match the allowlist below; if blank, apps cannot deploy).
APP_RUNTIME_DEFAULT_IMAGE=ghcr.io/teableio/teable-app-runtime:latest
# Allowed app image prefixes (comma-separated; must include the default image's prefix above).
APP_RUNTIME_ALLOWED_IMAGE_PREFIXES=ghcr.io/teableio/
# Registry prefix for the sandbox execution-plane images (execd/egress). Default is the public distribution registry (Aliyun-hosted, anonymously pullable worldwide).
OPENSANDBOX_REGISTRY=sandbox-registry.cn-zhangjiakou.cr.aliyuncs.com/opensandbox
# Third-party images default to :latest; pin digests here for production:
# MINIO_IMAGE=minio/minio@sha256:...
# MINIO_MC_IMAGE=minio/mc@sha256:...

# === Artifact store S3 / MinIO ===
S3_BUCKET=teable-app-artifacts
S3_REGION=us-east-1

# === App Runtime (local uses *.localhost) ===
# Browser access via http://<appId>.localhost (through caddy:80).
APP_RUNTIME_DOMAIN=localhost
APP_RUNTIME_PUBLIC_SCHEME=http

# === Networks (read by both compose and opensandbox.toml; rename only here) ===
APP_RUNTIME_DOCKER_NETWORK=teable-appnet
SANDBOX_DOCKER_NETWORK=teable-sandbox-net

# ============================================================================
# === Teable app (all-in-one) -- enabled only with ./apply.sh local --with-app ===
# Without --with-app this whole section can be ignored. Entry changes: Teable takes over the http://<host>:80 catch-all;
# the console moves to http://infra.localhost and app previews to http://<appId>.app.localhost.
# ============================================================================

# Teable app image. Docker deployments work out of the box with latest;
# to pin a version (recommended for production) run ./pin-image.sh, which resolves and writes it back here;
# for Kubernetes, paste the resolved reference into the image fields of your values.
TEABLE_IMAGE=ghcr.io/teableio/teable:latest
# Container timezone.
TIMEZONE=UTC

# --- Database / cache (leave passwords blank to auto-generate; PG publishes no host port) ---
TEABLE_DB_IMAGE=postgres:15.4
TEABLE_DB_NAME=teable
TEABLE_DB_USER=teable
TEABLE_DB_PASSWORD=
TEABLE_REDIS_IMAGE=redis:7.2.4
TEABLE_REDIS_PASSWORD=

# --- Attachment storage buckets ---
TEABLE_PUBLIC_BUCKET=teable-public
TEABLE_PRIVATE_BUCKET=teable-private

# --- Secrets (leave blank to auto-generate; the source-code defaults are public hardcoded values, so public deployments must generate per host) ---
BACKEND_STORAGE_ENCRYPTION_KEY=
BACKEND_STORAGE_ENCRYPTION_IV=
SANDBOX_JWT_SECRET=

# ============================================================================
# === Advanced (optional) -- usually untouched: leave blank and apply.sh derives everything from the LAN IP / local domains ===
# Fill in only if the derived addresses do not fit your network; your values win, apply.sh does not overwrite them.
# ============================================================================

# Presigned-URL host must match on both sides (uploader + infra-service); defaults to http://<LAN_IP>:9000.
# localhost will not work (inside a container it points at itself); if Teable is also on teable-appnet, http://minio:9000 works.
S3_ENDPOINT=
# External git clone address (default http://<LAN_IP>:8081; sandboxes clone over the internal network, so builds are unaffected).
GIT_REGISTRY_PUBLIC_URL=
# Public entry (default http://<LAN_IP>:80; must be reachable by both browsers and sandboxes, do not use localhost).
PUBLIC_ORIGIN=
# Attachment public endpoint (defaults <LAN_IP> / 9000 / false).
TEABLE_MINIO_ENDPOINT_HOST=
TEABLE_MINIO_ENDPOINT_PORT=
TEABLE_MINIO_USE_SSL=
# Sandbox endpoint/preview domain (default sandbox.localhost with --with-app, sandbox.localhost:8088 in infra-only mode).
# AI chat's agent connection cannot resolve local domains from inside containers yet (a sandbox-SDK improvement is planned);
# deploy/build flows are unaffected -- use cloud mode with a real domain for AI chat.
SANDBOX_PREVIEW_HOST=
