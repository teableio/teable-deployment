# Secret-bearing files generated by apply.sh, plus your hand-edited/copied .env. Never commit these.
.env
docker-compose.override.yml
opensandbox.generated.toml

# Re-include the two templates: a parent .gitignore's `.env*` rule would otherwise
# swallow them (child-directory negation overrides the parent rule).
!.env.local.example
!.env.server.example
